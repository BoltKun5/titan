{
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescriptreact",
    "typescript"
  ],
  "eslint.workingDirectories": [
    { "directory": "front", "changeProcessCWD": true },
    { "directory": "api-vokit", "changeProcessCWD": true }
  ],
  // Set the default
  "editor.formatOnSave": true,
  // "prettier.packageManager": "npm",
  "prettier.resolveGlobalModules": true,
  // Enable per-language
  "[javascript]": {
    "editor.formatOnSave": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  }
}
